{
  "expo": {
    "name": "AI Kitchen",
    "slug": "ai-kitchen",
    "scheme": "aikitchen",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.aikitchen.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Kitchen uses the microphone so you can talk to your cooking assistant while cooking.",
        "NSCameraUsageDescription": "AI Kitchen uses the camera to scan barcodes and nutrition labels so you don't have to type them.",
        "NSHealthShareUsageDescription": "AI Kitchen reads your weight, steps, and workouts so it can keep your calorie goal accurate.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.aikitchen.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Allow AI Kitchen to access your microphone while cooking."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "REPLACE_ME_AFTER_eas_init"
      }
    }
  }
}
